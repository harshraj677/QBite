{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Mobile: Flutter (debug)",
      "type": "dart",
      "request": "launch",
      "program": "apps/mobile/lib/main.dart",
      "cwd": "apps/mobile"
    },
    {
      "name": "Backend: Debug (ts-node-dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/apps/backend",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Admin: Debug (Next.js dev server)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/apps/admin",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
