# QBite Backend — Environment Variables (example)
# Copy to .env for local development. Placeholders only — never commit
# the real .env file (it's git-ignored; see the root .gitignore).

NODE_ENV=development
PORT=4000

# MongoDB — Atlas connection string in staging/production, a local
# mongod (or `docker compose up -d mongo`) in development.
MONGODB_URI=mongodb://localhost:27017/qbite_dev

# JWT
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# bcrypt cost factor for password hashing (4-31; 12 is the current default)
BCRYPT_SALT_ROUNDS=12

# Rate limiting (global baseline — see middlewares/rate-limiter.middleware.ts)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Redis (cache, OTP storage, Socket.IO adapter, BullMQ)
REDIS_URL=redis://localhost:6379

# IAM — optional, restricts POST /auth/register's collegeEmail to this
# domain (e.g. college.edu). Unset = any valid email accepted.
COLLEGE_EMAIL_DOMAIN=

# Razorpay — required for the Payments module (modules/payments/).
# KEY_ID/KEY_SECRET authenticate REST calls to Razorpay (Basic auth);
# WEBHOOK_SECRET is a separate secret from the Razorpay dashboard,
# used only to verify POST /payments/webhook's signature. Test-mode
# keys (rzp_test_...) are safe for local development.
RAZORPAY_KEY_ID=rzp_test_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# CDN / Object storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
