# QBite Backend — Environment Variables (example)
# Copy to .env for local development. Never commit the real .env file.

NODE_ENV=development
PORT=4000

# MongoDB
MONGO_URI=mongodb://localhost:27017/qbite_dev

# Redis (cache, OTP storage, Socket.IO adapter, BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# CORS
CORS_ORIGIN=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# CDN / Object storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
