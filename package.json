{
  "name": "qbite",
  "version": "0.1.0",
  "private": true,
  "description": "QBite — monorepo root. See docs/ for architecture, database, API, coding-standards, roadmap, and contribution documentation.",
  "workspaces": [
    "apps/backend",
    "apps/admin",
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "npm run dev -w @qbite/backend",
    "backend:build": "npm run build -w @qbite/backend",
    "backend:lint": "npm run lint -w @qbite/backend",
    "admin:dev": "npm run dev -w @qbite/admin",
    "admin:build": "npm run build -w @qbite/admin",
    "admin:lint": "npm run lint -w @qbite/admin",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
